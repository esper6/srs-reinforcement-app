generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String           @id @default(cuid())
  name              String?
  email             String?          @unique
  emailVerified     DateTime?
  image             String?
  approved          Boolean          @default(false)
  preferredProvider LlmProvider      @default(ANTHROPIC)
  accounts          Account[]
  sessions          Session[]
  masteries         ConceptMastery[]
  chatSessions      ChatSession[]
  apiKeys           UserApiKey[]
  vocabProgress     UserVocabProgress[]
}

model UserApiKey {
  id           String      @id @default(cuid())
  userId       String
  provider     LlmProvider
  encryptedKey String      @db.Text
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

enum LlmProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  CLAUDE_RELAY
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Curriculum Structure ───

model Curriculum {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  language    String    @default("")
  iconClass   String    @default("")
  order       Int       @default(0)
  sections    Section[]
}

model Section {
  id           String     @id @default(cuid())
  name         String
  order        Int        @default(0)
  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  concepts     Concept[]
}

model Concept {
  id             String           @id @default(cuid())
  title          String
  description    String
  lessonMarkdown String           @db.Text
  // Rounds redesign: pre-extracted facet names (3-5 per concept). New curricula
  // populate this at import time. Empty array means the concept has no facets
  // defined yet — round endpoints refuse to operate on it (graceful failure).
  facets         String[]         @default([])
  order          Int              @default(0)
  sectionId      String
  section        Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  masteries      ConceptMastery[]
  chatSessions   ChatSession[]
  vocabWords     VocabWord[]
}

model VocabWord {
  id         String              @id @default(cuid())
  conceptId  String
  term       String
  definition String              @db.Text
  order      Int                 @default(0)
  concept    Concept             @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  progress   UserVocabProgress[]

  @@index([conceptId])
}

model UserVocabProgress {
  id           String    @id @default(cuid())
  userId       String
  vocabWordId  String
  streak       Int       @default(0)
  easeFactor   Float     @default(2.5)
  interval     Float     @default(4)
  nextReviewAt DateTime  @default(now())
  totalCorrect Int       @default(0)
  totalWrong   Int       @default(0)
  dismissed    Boolean   @default(false)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabWord    VocabWord @relation(fields: [vocabWordId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabWordId])
  @@index([userId])
  @@index([vocabWordId])
}

// ─── User Progress ───

model ConceptMastery {
  id             String            @id @default(cuid())
  userId         String
  conceptId      String
  // Legacy 0-100 scoring (kept for back-compat during rounds-redesign Phases 2-5; removed in Phase 6).
  score          Float             @default(0)
  decayRate      Float             @default(0.1)
  lastReviewedAt DateTime          @default(now())
  reviewCount    Int               @default(0)
  // Rounds redesign: concept-level Mastered badge + synthesis cooldown.
  mastered               Boolean   @default(false)
  masteredAt             DateTime?
  synthesisCooldownUntil DateTime?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept           @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  subMasteries   SubConceptMastery[]

  @@unique([userId, conceptId])
  @@index([userId])
}

model SubConceptMastery {
  id               String         @id @default(cuid())
  conceptMasteryId String
  name             String
  // Legacy 0-100 scoring (kept for back-compat during rounds-redesign Phases 2-5; removed in Phase 6).
  score            Float          @default(0)
  decayRate        Float          @default(0.1)
  lastReviewedAt   DateTime       @default(now())
  // Rounds redesign: discrete level + Expert staircase + next-due timestamp.
  level            FacetLevel     @default(NOVICE)
  expertStage      Int            @default(0) // 0 = not yet at Expert; 1-3 = staircase position
  nextDueAt        DateTime       @default(now())
  conceptMastery   ConceptMastery @relation(fields: [conceptMasteryId], references: [id], onDelete: Cascade)

  @@unique([conceptMasteryId, name])
  @@index([conceptMasteryId])
  @@index([nextDueAt])
}

enum FacetLevel {
  NOVICE
  APPRENTICE
  JOURNEYMAN
  EXPERT
}

// ─── Conversation History ───

model ChatSession {
  id         String        @id @default(cuid())
  userId     String
  conceptId  String
  mode       SessionMode
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  messages   ChatMessage[]
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept    Concept       @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String      @db.Text
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

enum SessionMode {
  // Legacy modes — retained for existing data and current code; replaced by ROUND/SYNTHESIS/EXTRA_CREDIT in the rounds redesign.
  ASSESS
  LEARN
  REVIEW
  // Rounds redesign:
  ROUND
  SYNTHESIS
  EXTRA_CREDIT
}
