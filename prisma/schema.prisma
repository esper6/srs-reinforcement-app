generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  masteries     ConceptMastery[]
  chatSessions  ChatSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Curriculum Structure ───

model Curriculum {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  language    String    @default("")
  iconClass   String    @default("")
  order       Int       @default(0)
  sections    Section[]
}

model Section {
  id           String     @id @default(cuid())
  name         String
  order        Int        @default(0)
  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  concepts     Concept[]
}

model Concept {
  id             String           @id @default(cuid())
  title          String
  description    String
  lessonMarkdown String           @db.Text
  order          Int              @default(0)
  sectionId      String
  section        Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  masteries      ConceptMastery[]
  chatSessions   ChatSession[]
}

// ─── User Progress ───

model ConceptMastery {
  id             String            @id @default(cuid())
  userId         String
  conceptId      String
  score          Float             @default(0)
  decayRate      Float             @default(0.1)
  lastReviewedAt DateTime          @default(now())
  reviewCount    Int               @default(0)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept           @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  subMasteries   SubConceptMastery[]

  @@unique([userId, conceptId])
  @@index([userId])
}

model SubConceptMastery {
  id               String         @id @default(cuid())
  conceptMasteryId String
  name             String
  score            Float          @default(0)
  decayRate        Float          @default(0.1)
  lastReviewedAt   DateTime       @default(now())
  conceptMastery   ConceptMastery @relation(fields: [conceptMasteryId], references: [id], onDelete: Cascade)

  @@unique([conceptMasteryId, name])
  @@index([conceptMasteryId])
}

// ─── Conversation History ───

model ChatSession {
  id         String        @id @default(cuid())
  userId     String
  conceptId  String
  mode       SessionMode
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  messages   ChatMessage[]
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept    Concept       @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String      @db.Text
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

enum SessionMode {
  ASSESS
  LEARN
  REVIEW
}
